rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: Any signed-in user ───────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ─── Helper: Read the current user's Firestore document ───────────
    function getUserDoc() {
      let p = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(p) ? get(p) : null;
    }

    // ─── Helper: User is admin (either by email or by role field) ─────
    function isAdmin() {
      // System-level super admins by email
      return isAuth() && (
        request.auth.token.email == 'simsaraqari@gmail.com' ||
        request.auth.token.email == 'admin@internal.app' ||
        // OR the Firestore user doc says role == 'admin'
        (getUserDoc() != null && getUserDoc().data.role == 'admin')
      );
    }

    // ─── transactions ─────────────────────────────────────────────────
    match /transactions/{id} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── custody_accounts ─────────────────────────────────────────────
    match /custody_accounts/{id} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── categories ───────────────────────────────────────────────────
    match /categories/{id} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── persons ──────────────────────────────────────────────────────
    match /persons/{id} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── settings ─────────────────────────────────────────────────────
    match /settings/{id} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ─── reminders ────────────────────────────────────────────────────
    match /reminders/{id} {
      allow read:   if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── users ────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read their own doc; admins can read all
      allow get:    if isAuth() && (userId == request.auth.uid || isAdmin());
      allow list:   if isAdmin();
      // Anyone can create their own user doc on first sign-in
      allow create: if isAuth() && (userId == request.auth.uid || isAdmin());
      allow update: if isAuth() && (userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() && userId != request.auth.uid;
    }

    // ─── comments ─────────────────────────────────────────────────────
    match /comments/{id} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // ─── advertisements ───────────────────────────────────────────────
    match /advertisements/{id} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }
  }
}
