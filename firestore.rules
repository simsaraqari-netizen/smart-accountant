rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: signed-in ────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ─── Read the user doc once ───────────────────────────────────────
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // ─── Admin: any user whose Firestore role == 'admin' ─────────────
    // (no hardcoded emails — role is set in DB)
    function isAdmin() {
      return isAuth() && userData().role == 'admin';
    }

    // ─── Tenant isolation helper ──────────────────────────────────────
    function myTenantId() {
      return userData().tenantId;
    }

    // ─── transactions (stored with userId = tenantId) ─────────────────
    match /transactions/{id} {
      allow read:   if isAuth() && resource.data.userId == myTenantId();
      allow create: if isAdmin() && request.resource.data.userId == myTenantId();
      allow update: if isAdmin() && resource.data.userId == myTenantId();
      allow delete: if isAdmin() && resource.data.userId == myTenantId();
    }

    // ─── custody_accounts ────────────────────────────────────────────
    match /custody_accounts/{id} {
      allow read:   if isAuth() && resource.data.userId == myTenantId();
      allow create: if isAdmin() && request.resource.data.userId == myTenantId();
      allow update: if isAdmin() && resource.data.userId == myTenantId();
      allow delete: if isAdmin() && resource.data.userId == myTenantId();
    }

    // ─── categories ──────────────────────────────────────────────────
    match /categories/{id} {
      allow read:   if isAuth() && resource.data.userId == myTenantId();
      allow create: if isAdmin() && request.resource.data.userId == myTenantId();
      allow update: if isAdmin() && resource.data.userId == myTenantId();
      allow delete: if isAdmin() && resource.data.userId == myTenantId();
    }

    // ─── persons ─────────────────────────────────────────────────────
    match /persons/{id} {
      allow read:   if isAuth() && resource.data.userId == myTenantId();
      allow create: if isAdmin() && request.resource.data.userId == myTenantId();
      allow update: if isAdmin() && resource.data.userId == myTenantId();
      allow delete: if isAdmin() && resource.data.userId == myTenantId();
    }

    // ─── settings ────────────────────────────────────────────────────
    match /settings/{id} {
      allow read:  if isAuth() && id == myTenantId();
      allow write: if isAdmin() && id == myTenantId();
    }

    // ─── reminders (stored with tenantId) ────────────────────────────
    match /reminders/{id} {
      allow read:   if isAuth() && resource.data.tenantId == myTenantId();
      allow create: if isAdmin() && request.resource.data.tenantId == myTenantId();
      allow update: if isAdmin() && resource.data.tenantId == myTenantId();
      allow delete: if isAdmin() && resource.data.tenantId == myTenantId();
    }

    // ─── users ───────────────────────────────────────────────────────
    match /users/{userId} {
      // Every user can read their own doc; admins can read all
      allow get:    if isAuth() && (userId == request.auth.uid || isAdmin());
      allow list:   if isAdmin();
      allow create: if isAdmin() && request.resource.data.tenantId == myTenantId();
      allow update: if isAdmin() && resource.data.tenantId == myTenantId();
      allow delete: if isAdmin() && userId != request.auth.uid;
    }

    // ─── comments & advertisements ───────────────────────────────────
    match /comments/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    match /advertisements/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }
  }
}
