rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: Any signed-in user ───────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    // ─── Helper: Read the current user's Firestore document ───────────
    function getUserDoc() {
      let p = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(p) ? get(p) : null;
    }

    function isRegistered() {
      return isAuth() && getUserDoc() != null;
    }

    function tenantId() {
      return getUserDoc().data.tenantId;
    }

    // ─── Helper: User is admin (either by email or by role field) ─────
    function isAdmin() {
      // System-level super admins by email
      return isAuth() && (
        request.auth.token.email == 'simsaraqari@gmail.com' ||
        request.auth.token.email == 'admin@internal.app' ||
        // OR the Firestore user doc says role == 'admin'
        (getUserDoc() != null && getUserDoc().data.role == 'admin')
      );
    }

    function canReadTenantDoc() {
      return isRegistered() && resource.data.userId == tenantId();
    }

    function canCreateTenantDoc() {
      return isAdmin() && isRegistered() && request.resource.data.userId == tenantId();
    }

    function canWriteTenantDoc() {
      return isAdmin() && isRegistered() && resource.data.userId == tenantId();
    }

    function canReadTenantScopedDoc() {
      return isRegistered() && resource.data.tenantId == tenantId();
    }

    function canCreateTenantScopedDoc() {
      return isAdmin() && isRegistered() && request.resource.data.tenantId == tenantId();
    }

    function canWriteTenantScopedDoc() {
      return isAdmin() && isRegistered() && resource.data.tenantId == tenantId();
    }

    // ─── transactions ─────────────────────────────────────────────────
    match /transactions/{id} {
      allow read:   if canReadTenantDoc();
      allow create: if canCreateTenantDoc();
      allow update: if canWriteTenantDoc() && request.resource.data.userId == resource.data.userId;
      allow delete: if canWriteTenantDoc();
    }

    // ─── custody_accounts ─────────────────────────────────────────────
    match /custody_accounts/{id} {
      allow read:   if canReadTenantDoc();
      allow create: if canCreateTenantDoc();
      allow update: if canWriteTenantDoc() && request.resource.data.userId == resource.data.userId;
      allow delete: if canWriteTenantDoc();
    }

    // ─── categories ───────────────────────────────────────────────────
    match /categories/{id} {
      allow read:   if canReadTenantDoc();
      allow create: if canCreateTenantDoc();
      allow update: if canWriteTenantDoc() && request.resource.data.userId == resource.data.userId;
      allow delete: if canWriteTenantDoc();
    }

    // ─── persons ──────────────────────────────────────────────────────
    match /persons/{id} {
      allow read:   if canReadTenantDoc();
      allow create: if canCreateTenantDoc();
      allow update: if canWriteTenantDoc() && request.resource.data.userId == resource.data.userId;
      allow delete: if canWriteTenantDoc();
    }

    // ─── settings ─────────────────────────────────────────────────────
    match /settings/{id} {
      allow read:   if isRegistered() && id == tenantId();
      allow write:  if isAdmin() && isRegistered() && id == tenantId();
    }

    // ─── reminders ────────────────────────────────────────────────────
    match /reminders/{id} {
      allow read:   if canReadTenantScopedDoc();
      allow create: if canCreateTenantScopedDoc();
      allow update: if canWriteTenantScopedDoc() && request.resource.data.tenantId == resource.data.tenantId;
      allow delete: if canWriteTenantScopedDoc();
    }

    // ─── users ────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read their own doc; admins can read all
      allow get:    if isAuth() && (userId == request.auth.uid || isAdmin());
      allow list:   if isAdmin();
      allow create: if isAdmin() && isRegistered() && request.resource.data.tenantId == tenantId();
      allow update: if isAdmin()
        && isRegistered()
        && resource.data.tenantId == tenantId()
        && request.resource.data.tenantId == resource.data.tenantId;
      allow delete: if isAdmin() && userId != request.auth.uid;
    }

    // ─── comments ─────────────────────────────────────────────────────
    match /comments/{id} {
      allow read:   if isRegistered();
      allow write:  if isAdmin() && isRegistered();
    }

    // ─── advertisements ───────────────────────────────────────────────
    match /advertisements/{id} {
      allow read:   if isRegistered();
      allow write:  if isAdmin() && isRegistered();
    }
  }
}
